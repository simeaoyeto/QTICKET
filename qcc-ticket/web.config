<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="login.php" />
        <add value="index.php" />
      </files>
    </defaultDocument>
    <staticContent>
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config" />
          <add segment="includes" />
        </hiddenSegments>
      </requestFiltering>
    </security>
    <httpErrors errorMode="DetailedLocalOnly" />
  </system.webServer>
</configuration>
